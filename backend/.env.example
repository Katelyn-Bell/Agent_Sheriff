OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7
# ANTHROPIC_API_KEY=  # fallback if OPENAI_API_KEY/OPENROUTER_API_KEY is not set
APPROVAL_TIMEOUT_S=300
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=<your bot token from @BotFather>
TELEGRAM_CHAT_ID=<your chat or group ID> 
# Leave false when OpenClaw owns Telegram callbacks. Set true only if Sheriff should poll Telegram directly.
TELEGRAM_POLL_CALLBACKS=false
OAUTH_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback
SESSION_SECRET=
SESSION_COOKIE_NAME=agentsheriff_session
SESSION_MAX_AGE_S=604800
COOKIE_SECURE=false
FRONTEND_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
AGENTSHERIFF_ALLOW_REAL_SHELL=1
